{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "args": true,
          "name": "node-homebrew",
          "cmd": "/opt/homebrew/bin/node"
        },
        {
          "args": true,
          "name": "node-local",
          "cmd": "/usr/local/bin/node"
        },
        {
          "args": true,
          "name": "node",
          "cmd": "node"
        }
      ]
    }
  ]
}
